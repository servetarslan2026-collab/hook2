# Server
SERVER_PORT=3000

# PostgreSQL
DATABASE_URL=postgres://webhook:webhook_secret@localhost:5432/webhook_service?sslmode=disable

# NATS
NATS_URL=nats://localhost:4222

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=change-this-to-a-strong-secret-in-production
JWT_EXPIRY=24h

# Worker
WORKER_COUNT=4

# Frontend
FRONTEND_URL=http://localhost:5173
