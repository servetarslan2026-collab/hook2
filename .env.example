# =============================================================================
# Webhook Service — Environment Variables
# =============================================================================
# Copy this file to .env and update values for your environment.
# NEVER commit .env to version control!
# =============================================================================

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
SERVER_PORT=3000                 # API server port

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------
POSTGRES_USER=webhook            # Database user
POSTGRES_PASSWORD=webhook_secret # CHANGE THIS in production!
POSTGRES_DB=webhook_service      # Database name
DATABASE_URL=postgres://webhook:webhook_secret@localhost:5432/webhook_service?sslmode=disable

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_PASSWORD=                  # Set a strong password in production
REDIS_URL=redis://localhost:6379 # Redis connection URL

# -----------------------------------------------------------------------------
# NATS
# -----------------------------------------------------------------------------
NATS_URL=nats://localhost:4222   # NATS connection URL

# -----------------------------------------------------------------------------
# JWT Authentication
# -----------------------------------------------------------------------------
JWT_SECRET=change-this-to-a-strong-secret-in-production  # CHANGE THIS! Min 32 chars
JWT_EXPIRY=24h                   # Token expiry (e.g., 24h, 7d)

# -----------------------------------------------------------------------------
# Worker
# -----------------------------------------------------------------------------
WORKER_COUNT=4                   # Number of webhook delivery workers

# -----------------------------------------------------------------------------
# Frontend
# -----------------------------------------------------------------------------
FRONTEND_URL=http://localhost:5173  # CORS origin
PUBLIC_API_URL=/api/v1              # Frontend API URL (relative or absolute)

# -----------------------------------------------------------------------------
# Backup
# -----------------------------------------------------------------------------
BACKUP_RETENTION_DAYS=7          # Days to keep database backups

# -----------------------------------------------------------------------------
# Production Checklist
# -----------------------------------------------------------------------------
# [ ] Strong JWT_SECRET (32+ random characters)
# [ ] Strong POSTGRES_PASSWORD
# [ ] Strong REDIS_PASSWORD
# [ ] FRONTEND_URL set to production domain
# [ ] SSL/TLS via Caddy or reverse proxy
# [ ] Database backup cron configured
# [ ] Monitoring (Prometheus) endpoint secured
